# NextAuth v5 — Google provider
# Generate AUTH_SECRET with: npx auth secret
AUTH_SECRET=

# Google OAuth 2.0 Client (Google Cloud Console → APIs & Services → Credentials)
# Authorised JavaScript origins:
#   http://localhost:24301
#   https://cac-snowy.vercel.app  (or your prod URL)
# Authorised redirect URIs:
#   http://localhost:24301/api/auth/callback/google
#   https://cac-snowy.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional — override the base URL when deploying to a custom domain
# AUTH_URL=https://cca.example.com
